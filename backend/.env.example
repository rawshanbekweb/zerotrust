# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ─────────────────────────────────────────────
# DATABASE
# Default: SQLite for local dev — change to
# postgresql://user:pass@localhost:5432/zerotrust
# for production
# ─────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────
# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_byte_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
# ENCRYPTION (for sensitive fields)
# ─────────────────────────────────────────────
ENCRYPTION_KEY=replace_with_32_byte_hex
